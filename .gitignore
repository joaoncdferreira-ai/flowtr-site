# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Source screenshots contain PII (founder's face, name, email) before
# sanitisation. Keep them local-only; the sanitised versions in
# public/screenshots-clean/ are what the site actually serves.
/public/screenshots/
# Verification thumbnails generated by the QA pipeline.
/public/screenshots-clean/_thumbs/
/public/screenshots/_thumbs/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
