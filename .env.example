# Public site URL (used by sitemap/robots/canonical). Set to the production
# origin in Vercel; leave unset for local dev.
NEXT_PUBLIC_SITE_URL=https://flowtr.app

# ---------- Waitlist provider ----------
# Option A: Resend (recommended). Create an API key at resend.com/api-keys
# and an Audience at resend.com/audiences. Then set both:
RESEND_API_KEY=re_xxx
RESEND_AUDIENCE_ID=00000000-0000-0000-0000-000000000000

# Option B: any HTTP endpoint that accepts {email, source}. Used as a fallback
# when RESEND_* are absent. Authorization header is added if WAITLIST_FORWARD_KEY is set.
# WAITLIST_FORWARD_URL=https://hooks.example.com/flowtr-waitlist
# WAITLIST_FORWARD_KEY=secret
